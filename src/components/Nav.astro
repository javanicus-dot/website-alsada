---
// Komponen Nav. Dipakai di semua halaman.
// Catatan SEO: link eksternal (misal IG, FB) tambahkan rel="noopener" + target="_blank".
const links = [
  { href: "/", label: "Beranda" },
  { href: "/#tentang", label: "Tentang" },
  { href: "/#produk", label: "Produk" },
  { href: "/tentang", label: "Mitra" },
  { href: "/artikel", label: "Artikel" },
  { href: "/#faq", label: "FAQ" },
];
---

<header class="nav" id="nav">
  <div class="wrap">
    <div class="nav-inner">
      <a href="/" class="brand"><span class="mark"><img src="/assets/logo.png" alt="Logo Alsada" width="32" height="32" /></span>ALSADA</a>
      <nav class="links" id="navLinks">
        {links.map((l) => (
          <a href={l.href}>{l.label}</a>
        ))}
      </nav>
      <div class="nav-right">
        <a href="/kontak" class="btn btn-lime">Hubungi Kami <span class="arrow">↗</span></a>
        <button class="burger" id="burger" aria-label="Menu" aria-controls="navLinks" aria-expanded="false"><span></span><span></span><span></span></button>
      </div>
    </div>
  </div>
</header>

<style>
  /* Logo menggantikan huruf "A" di dalam .mark tanpa mengubah ukuran/penempatan kotak.
     Kotak .mark tetap 32x32 (lihat global.css); img hanya mengisi area di dalamnya. */
  .brand .mark img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    box-sizing: border-box;
    padding: 3px;
  }
</style>

<script>
  // Burger menu toggle (mobile)
  const burger = document.getElementById('burger');
  const links = document.getElementById('navLinks');
  const setExpanded = () =>
    burger?.setAttribute('aria-expanded', String(!!links?.classList.contains('open')));
  burger?.addEventListener('click', () => {
    links?.classList.toggle('open');
    setExpanded();
  });
  links?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      links?.classList.remove('open');
      setExpanded();
    })
  );
</script>
