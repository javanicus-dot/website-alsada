<section class="sec" id="produk">
  <div class="wrap">
    <div class="lead-row reveal">
      <h2 class="h2">Lima Lini Usaha, Satu Ekosistem Terintegrasi</h2>
      <p>
        Setiap lini usaha Alsada saling menopang untuk menghadirkan satu
        ekosistem peternakan yang mampu mendukung kebutuhan pangan, ternak, dan
        kemitraan secara lebih terpadu.
      </p>
    </div>
    <div class="pgrid">
      {
        products.map((p) => (
          <div class="pcard reveal">
            <div class="thumb">
              <img src={p.img} alt={p.alt} loading="lazy" decoding="async" />
            </div>
            <div>
              <h4>{p.title}</h4>
              <p>{p.desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
