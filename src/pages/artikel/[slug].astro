---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { getAllArticleSlugs, getArticleBySlug } from "../../lib/sanity";
import { portableTextToHtml } from "../../lib/portable-text";
import { urlFor } from "../../lib/sanity";

// Generate satu halaman statis per artikel di Sanity.
export async function getStaticPaths() {
  const slugs = await getAllArticleSlugs();
  return slugs.map((slug) => ({
    params: { slug },
  }));
}

// Ambil artikel berdasarkan slug dari URL.
const { slug } = Astro.params;
const article = await getArticleBySlug(slug);

// 404 kalau artikel tidak ditemukan
if (!article) {
  return Astro.redirect("/404");
}

const dt = new Date(article.publishedAt);
const formatted = dt.toLocaleDateString("id-ID", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

// Render Portable Text body ke HTML
const bodyHtml = portableTextToHtml(article.body);

const title = `${article.title} — Alsada`;
const description = article.excerpt || "";
const canonical = new URL(Astro.url.pathname, "https://alsada.co.id/").toString();
const schemaImage = article.coverImage
  ? urlFor(article.coverImage).width(1200).height(630).url()
  : "https://alsada.co.id/assets/og-image.jpg";

// JSON-LD Article — dipasang inline di head via <script type="application/ld+json">.
// Di-allow CSP lewat path override /artikel/* di public/_headers.
const articleLdJson = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: article.title,
  description: article.excerpt,
  image: schemaImage,
  datePublished: article.publishedAt,
  dateModified: article.publishedAt,
  author: {
    "@type": "Organization",
    name: "PT. Alsada Barokah Nusantara",
    url: "https://alsada.co.id/",
  },
  publisher: {
    "@type": "Organization",
    name: "PT. Alsada Barokah Nusantara",
    url: "https://alsada.co.id/",
    logo: {
      "@type": "ImageObject",
      url: "https://alsada.co.id/assets/logo.png",
    },
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonical,
  },
};
---

<Layout title={title} description={description} ogType="article">
  <Fragment slot="head">
    <!-- Metadata khusus artikel (CSP-safe, tanpa script inline). -->
    <meta property="article:published_time" content={article.publishedAt} />
    {article.category && <meta property="article:section" content={article.category} />}
    <meta property="article:publisher" content="PT. Alsada Barokah Nusantara" />
    <!-- Structured Data: Article (Google Rich Results) -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(articleLdJson)} />
  </Fragment>
  <Nav />
  <main id="main-content">
    <article itemscope itemtype="https://schema.org/Article">
      <meta itemprop="author" content="PT. Alsada Barokah Nusantara" />
      <meta itemprop="publisher" content="PT. Alsada Barokah Nusantara" />
      <meta itemprop="mainEntityOfPage" content={canonical} />
      <meta itemprop="dateModified" content={article.publishedAt} />
      <meta itemprop="image" content={schemaImage} />
      <header class="article-hero">
        {article.coverImage && (
          <img
            class="article-cover"
            src={urlFor(article.coverImage).width(1200).height(600).url()}
            alt={article.title}
            loading="eager"
            decoding="async"
          />
        )}
        <div class="wrap">
          <div class="meta">
            <a href="/artikel" style="color:inherit;opacity:.7">← Semua Artikel</a>
            <span>•</span>
            <span itemprop="articleSection">{article.category}</span>
            <span>•</span>
            <time datetime={article.publishedAt} itemprop="datePublished">{formatted}</time>
          </div>
          <h1 itemprop="headline">{article.title}</h1>
          {article.excerpt && <p class="lead" itemprop="description">{article.excerpt}</p>}
        </div>
      </header>

      <div class="wrap">
        <div class="article-body" itemprop="articleBody" set:html={bodyHtml} />

        <div class="article-actions">
          <a href="/artikel" class="btn btn-lime">← Kembali ke daftar artikel</a>
          <a href="/kontak" class="btn btn-outline">Diskusikan dengan kami</a>
        </div>
      </div>
    </article>
  </main>
  <Footer />
</Layout>
