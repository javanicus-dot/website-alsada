---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { getAllArticleSlugs, getArticleBySlug, urlFor, type ArticleFull } from "../../lib/sanity";
import { portableTextToHtml } from "../../lib/portable-text";

// Generate satu halaman statis per artikel di Sanity.
export async function getStaticPaths() {
  const slugs = await getAllArticleSlugs();
  return slugs.map((slug) => ({
    params: { slug },
  }));
}

// Ambil artikel berdasarkan slug dari URL.
const { slug } = Astro.params;
const article = await getArticleBySlug(slug);

// Guard: kalau artikel tidak ditemukan, kembalikan HTTP 404 ASLI (bukan redirect).
// Redirect ke /404 menghasilkan soft-404 di mata Google. Dengan getStaticPaths,
// jalur ini praktis tidak akan pernah tereksekusi, tapi tetap dibuat benar.
if (!article) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const dt = new Date(article.publishedAt);
const formatted = dt.toLocaleDateString("id-ID", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

// Tanggal modifikasi nyata dari Sanity (_updatedAt) — sinyal freshness untuk Google.
// Fallback ke publishedAt kalau updatedAt belum tersedia.
const dateModified = article.updatedAt || article.publishedAt;

// Render Portable Text body ke HTML
const bodyHtml = portableTextToHtml(article.body);

function generateMetaDescription(article: ArticleFull): string {
  const ex = article.excerpt?.trim();
  if (ex && ex.length >= 20 && !/^[a-zA-Z,\s]{3,}$/.test(ex)) {
    return ex;
  }
  if (article.body?.length) {
    let combined = "";
    for (const block of article.body) {
      if (block._type === "block" && block.children?.length) {
        const text = block.children.map((c: any) => c.text || "").join("").trim();
        if (text.length < 10) continue;
        combined += (combined ? " " : "") + text;
        if (combined.length >= 120) break;
      }
    }
    if (combined.length >= 30) {
      return combined.length > 160 ? combined.slice(0, combined.lastIndexOf(" ", 157)) + "..." : combined;
    }
  }
  return "";
}

const title = `${article.title} — Alsada`;
const description = generateMetaDescription(article);
const canonical = new URL(
  Astro.url.pathname,
  "https://alsada.co.id/",
).toString();
const schemaImage = article.coverImage?.asset?._ref
  ? urlFor(article.coverImage).width(1200).height(630).url()
  : "https://alsada.co.id/assets/og-image.jpg";

// JSON-LD (Article + BreadcrumbList) dalam satu @graph — dipasang inline di head.
// Di-allow CSP lewat path override /artikel/* (unsafe-inline) di public/_headers,
// jadi TIDAK perlu hash sha256 (isi per-artikel berbeda-beda).
const articleLdJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: article.title,
      description: description,
      image: schemaImage,
      datePublished: article.publishedAt,
      dateModified: dateModified,
      author: {
        "@type": "Organization",
        name: "PT. Alsada Barokah Nusantara",
        url: "https://alsada.co.id/",
      },
      publisher: {
        "@type": "Organization",
        name: "PT. Alsada Barokah Nusantara",
        url: "https://alsada.co.id/",
        logo: {
          "@type": "ImageObject",
          url: "https://alsada.co.id/assets/logo.png",
        },
      },
      mainEntityOfPage: {
        "@type": "WebPage",
        "@id": canonical,
      },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Beranda",
          item: "https://alsada.co.id/",
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Artikel",
          item: "https://alsada.co.id/artikel/",
        },
        {
          "@type": "ListItem",
          position: 3,
          name: article.title,
          item: canonical,
        },
      ],
    },
  ],
};
---

<Layout title={title} description={description} ogType="article">
  <Fragment slot="head">
    <!-- Metadata khusus artikel (CSP-safe, tanpa script inline). -->
    <meta property="article:published_time" content={article.publishedAt} />
    <meta property="article:modified_time" content={dateModified} />
    {
      article.category && (
        <meta property="article:section" content={article.category} />
      )
    }
    <meta property="article:publisher" content="PT. Alsada Barokah Nusantara" />
    <!-- Structured Data: Article + BreadcrumbList (Google Rich Results) -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(articleLdJson)}
    />
  </Fragment>
  <Nav />
  <main id="main-content">
    <article itemscope itemtype="https://schema.org/Article">
      <meta itemprop="author" content="PT. Alsada Barokah Nusantara" />
      <meta itemprop="publisher" content="PT. Alsada Barokah Nusantara" />
      <meta itemprop="mainEntityOfPage" content={canonical} />
      <meta itemprop="dateModified" content={dateModified} />
      <meta itemprop="image" content={schemaImage} />
      <header class="article-hero">
        <div class="wrap">
          <div class="meta">
            <a href="/artikel" style="color:inherit;opacity:.7"
              >← Semua Artikel</a
            >
            <span>•</span>
            <span itemprop="articleSection">{article.category}</span>
            <span>•</span>
            <time datetime={article.publishedAt} itemprop="datePublished"
              >{formatted}</time
            >
          </div>
          <h1 itemprop="headline">{article.title}</h1>
          {
            article.excerpt && (
              <p class="lead" itemprop="description">
                {article.excerpt}
              </p>
            )
          }
          {
            article.coverImage?.asset?._ref && (
              <img
                class="article-cover"
                src={urlFor(article.coverImage).url()}
                alt={article.title}
                loading="eager"
                decoding="async"
              />
            )
          }
        </div>
      </header>

      <div class="wrap">
        <div class="article-body" itemprop="articleBody" set:html={bodyHtml} />

        <div class="article-actions">
          <a href="/artikel" class="btn btn-lime">← Kembali ke daftar artikel</a
          >
          <a href="/kontak" class="btn btn-outline">Diskusikan dengan kami</a>
        </div>
      </div>
    </article>
  </main>
  <Footer />
</Layout>
