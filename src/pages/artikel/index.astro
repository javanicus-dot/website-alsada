---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import ArticleRow from "../../components/ArticleRow.astro";
import { getAllArticles } from "../../lib/sanity";

const title = "Artikel & Wawasan Peternakan — PT Alsada Barokah Nusantara";
const description =
  "Wawasan dan praktik peternakan modern dari Alsada: sapi FH, jual-beli sapi, daging premium, breeding, dan ketahanan pangan.";

// Ambil semua artikel dari Sanity, diurut dari terbaru.
const articles = await getAllArticles();
---

<Layout title={title} description={description}>
  <Nav />
  <main id="main-content">
    <section class="article-hero article-hero--list">
      <div class="wrap">
        <span class="pill-badge">Wawasan Peternakan</span>
        <h1 class="article-hero__title-list">Artikel & Wawasan Peternakan</h1>
        <p class="lead">
          Praktik peternakan, cerita ternak, dan kabar terbaru dari para
          peternak.
        </p>
      </div>
    </section>

    <section class="sec sec--tight-top">
      <div class="wrap">
        {
          articles.length > 0 ? (
            <div class="article-list">
              {articles.map((a) => (
                <ArticleRow
                  slug={a.slug}
                  title={a.title}
                  excerpt={a.excerpt}
                  date={a.publishedAt}
                  category={a.category}
                />
              ))}
            </div>
          ) : (
            <div class="empty-state">
              <p>
                Belum ada artikel. Silakan tambahkan artikel di Sanity Studio.
              </p>
            </div>
          )
        }
      </div>
    </section>
  </main>
  <Footer />
</Layout>
