# Cloudflare Pages security headers untuk Alsada.
# Taruh file ini di: public/_headers  (akan ikut ter-deploy ke root situs).
#
# CSP disesuaikan dengan resource yang dipakai situs:
#   - Google Fonts        : fonts.googleapis.com (style), fonts.gstatic.com (font)
#   - Cloudflare Turnstile: challenges.cloudflare.com (script + frame + xhr)
#   - Sanity image CDN    : cdn.sanity.io (gambar artikel)
#   - Google Apps Script  : script.google.com / script.googleusercontent.com (submit form)
#   - Analytics           : GA4 (googletagmanager.com) + script inline GA4 di-allow lewat hash
#                            sha256-bKMQtcThm... ; Cloudflare Web Analytics via static.cloudflareinsights.com
#                            (script-src) + cloudflareinsights.com (connect-src).
#   - JSON-LD inline       : di-allow lewat hash sha256 pada script-src (lihat di bawah).
#                            PENTING: ada DUA hash JSON-LD sekarang:
#                              1) Organization + WebSite (@graph) di src/layouts/Layout.astro
#                              2) FAQPage di src/components/FAQ.astro
#                            Kalau salah satu isinya diubah, hash WAJIB di-regenerasi
#                            (lihat docs) atau structured data diblokir browser.
# Jika nanti menambah embed (YouTube/Vimeo/Maps), tambahkan origin-nya ke frame-src/img-src.

/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'sha256-TjD6coXR4aFxMk2PcLHU32Xpmga3066HNuB/kHfmGxk=' 'sha256-VkdIHadsds3WgqPKVuMpa3/34ozCMosPbDVRvLsn4Gs=' 'sha256-bKMQtcThm+XMRunZEoF1QwlOY2I4x0LwKwZzmiyxZA8=' https://challenges.cloudflare.com https://www.googletagmanager.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://cdn.sanity.io https://www.google-analytics.com; connect-src 'self' https://challenges.cloudflare.com https://script.google.com https://script.googleusercontent.com https://*.sanity.io https://*.google-analytics.com https://*.analytics.google.com https://cloudflareinsights.com; frame-src https://challenges.cloudflare.com; upgrade-insecure-requests
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/assets/products/*
  Cache-Control: public, max-age=31536000, immutable

/assets/about/*
  Cache-Control: public, max-age=31536000, immutable

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.*
  Cache-Control: public, max-age=86400

# Halaman artikel: JSON-LD Article inline (isi per artikel berbeda-beda,
# hash SHA tidak praktis di-hardcode). Override CSP untuk path ini saja.
/artikel/*/
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com https://www.googletagmanager.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://cdn.sanity.io https://www.google-analytics.com; connect-src 'self' https://challenges.cloudflare.com https://script.google.com https://script.googleusercontent.com https://*.sanity.io https://*.google-analytics.com https://*.analytics.google.com https://cloudflareinsights.com; frame-src https://challenges.cloudflare.com;
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
